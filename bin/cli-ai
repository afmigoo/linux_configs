#!/usr/bin/env bash
set -euo pipefail

MAX_CONTEXT_LINES=500
MAX_CONTEXT_CHARS=50000
DEFAULT_SYSTEM_PROMPT=$(cat <<'EOF'
You are a terminal AI assistant.

Formatting:
- Lists are fine. No other markdown unless it helps readability.
- A single command or one-liner must be output as plain text (no code block, no backticks).
- When asked for one command, reply with exactly one — the simplest that works.
- Optionally precede a command with one short lead-in line, then a blank line, then the command.
- Multi-line snippets may use code blocks.

Be concise. Omit preamble unless it prevents a mistake.
EOF
)

count_lines() {
    [[ -z "$1" ]] && { echo 0; return; }
    printf '%s\n' "$1" | wc -l | tr -d ' '
}

count_chars() {
    printf '%s' "$1" | wc -c | tr -d ' '
}

stream_response() {
    local line data error content reasoning
    local reasoning_started=false reasoning_done=false wrote_output=false

    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ -z "$line" ]] && continue
        [[ "$line" == event:* ]] && continue

        if [[ "$line" != data:* ]]; then
            if [[ "$line" == \{* ]]; then
                error=$(jq -rj '.error.message // empty' <<<"$line"; printf 'x')
                if [[ "$error" != "x" ]]; then
                    echo "error: API returned: ${error%x}" >&2
                    return 1
                fi
            fi
            continue
        fi

        data="${line#data:}"
        data="${data# }"
        [[ "$data" == "[DONE]" ]] && break

        error=$(jq -rj '.error.message // empty' <<<"$data"; printf 'x')
        if [[ "$error" != "x" ]]; then
            echo "error: API returned: ${error%x}" >&2
            return 1
        fi

        if $VERBOSE; then
            reasoning=$(jq -rj '.choices[0].delta.reasoning_content // empty' <<<"$data"; printf 'x')
            if [[ "$reasoning" != "x" ]]; then
                reasoning="${reasoning%x}"
                if ! $reasoning_started; then
                    echo "--- start thinking ---"
                    reasoning_started=true
                fi
                printf '%s' "$reasoning"
                wrote_output=true
            fi
        fi

        content=$(jq -rj '.choices[0].delta.content // empty' <<<"$data"; printf 'x')
        if [[ "$content" != "x" ]]; then
            content="${content%x}"
            if $VERBOSE && $reasoning_started && ! $reasoning_done; then
                printf '\n--- end thinking ---\n'
                reasoning_done=true
            fi
            printf '%s' "$content"
            wrote_output=true
        fi
    done

    if $VERBOSE && $reasoning_started && ! $reasoning_done; then
        printf '\n--- end thinking ---\n'
    fi

    if $wrote_output; then
        printf '\n'
    fi
}

usage() {
    cat >&2 <<EOF
Usage: $(basename "$0") [OPTIONS] "question"
       <stdin> | $(basename "$0") [OPTIONS] "question"

Options:
  -i, --input-file <file>          Include file as context (repeatable)
  -p, --system-prompt <file>       Load system prompt from file
  -e, --api-endpoint <url>         API base URL (overrides CLI_AI_ENDPOINT)
  -m, --model-name <model>         Model name (overrides CLI_AI_MODEL)
  -T, --think                      Enable thinking
  -x, --exec <command>             Run command and include its stdout/stderr as context
      --ignore-context-limit       Disable context size limits (default: ${MAX_CONTEXT_LINES} lines / ${MAX_CONTEXT_CHARS} chars)
  -v, --verbose                    Show processing info on stderr and stream reasoning to stdout
  -h, --help                       Show this help

Environment:
  CLI_AI_ENDPOINT   API base URL (required — /chat/completions appended automatically)
  CLI_AI_MODEL      Model name (required)
  CLI_AI_API_KEY    API key (optional — omitted if unset)

Examples:
  cat app.log | tail -n10 | $(basename "$0") "what is the most common status code?"
  $(basename "$0") "gimme a command to get unique status codes from nginx log"
  $(basename "$0") -i app.conf -i db.conf "how does this work?"
  $(basename "$0") -T "explain this error in depth"
EOF
    exit 1
}

ENDPOINT="${CLI_AI_ENDPOINT:-}"
MODEL="${CLI_AI_MODEL:-}"
API_KEY="${CLI_AI_API_KEY:-}"
SYSTEM_PROMPT="$DEFAULT_SYSTEM_PROMPT"
SYSTEM_PROMPT_FILE=""
INPUT_FILES=()
THINKING=false
VERBOSE=false
ENFORCE_LIMIT=true
EXEC_CMD=""

verbose() {
    if $VERBOSE; then
        echo "$*" >&2
    fi
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -i|--input-file)
            INPUT_FILES+=("$2"); shift 2 ;;
        -p|--system-prompt)
            SYSTEM_PROMPT_FILE="$2"; shift 2 ;;
        -e|--api-endpoint)
            ENDPOINT="$2"; shift 2 ;;
        -m|--model-name)
            MODEL="$2"; shift 2 ;;
        -T|--think)
            THINKING=true; shift ;;
        -x|--exec)
            [[ -z "${2:-}" ]] && { echo "error: -x/--exec requires a command" >&2; exit 1; }
            EXEC_CMD="$2"; shift 2 ;;
        --ignore-context-limit)
            ENFORCE_LIMIT=false; shift ;;
        -v|--verbose)
            VERBOSE=true; shift ;;
        -h|--help)
            usage; exit 0 ;;
        --)
            shift; break ;;
        -*)
            echo "error: unknown option $1" >&2; usage ;;
        *)
            break ;;
    esac
done

if [[ -z "$ENDPOINT" ]]; then
    echo "error: CLI_AI_ENDPOINT not set (use -e or set env var)" >&2
    exit 1
fi

ENDPOINT="${ENDPOINT%/chat/completions}"
API_URL="${ENDPOINT}/chat/completions"

if [[ -z "$MODEL" ]]; then
    echo "error: CLI_AI_MODEL not set (use -m or set env var)" >&2
    exit 1
fi

if [[ -n "$SYSTEM_PROMPT_FILE" ]]; then
    [[ -f "$SYSTEM_PROMPT_FILE" ]] || { echo "error: system prompt file not found: $SYSTEM_PROMPT_FILE" >&2; exit 1; }
    SYSTEM_PROMPT=$(<"$SYSTEM_PROMPT_FILE")
fi

if [[ $# -eq 0 ]]; then
    echo "error: no question provided" >&2
    usage
fi

QUESTION="$*"

# Validate input files exist before blocking on stdin
for f in "${INPUT_FILES[@]}"; do
    [[ -f "$f" ]] || { echo "error: input file not found: $f" >&2; exit 1; }
done

CONTEXT=""
STDIN_CONTENT=""

# Read piped stdin
if [[ -z "$EXEC_CMD" ]] && [[ ! -t 0 ]]; then
    verbose "reading stdin..."
    STDIN_CONTENT=$(cat)
    if [[ -n "$STDIN_CONTENT" ]]; then
        verbose "stdin: $(count_lines "$STDIN_CONTENT") lines, $(count_chars "$STDIN_CONTENT") chars"
        CONTEXT+="<stdin>
$STDIN_CONTENT
</stdin>

"
    else
        verbose "stdin: empty"
    fi
else
    verbose "stdin: none"
fi

# Read -i input files
for f in "${INPUT_FILES[@]}"; do
    verbose "reading file: $f"
    file_content=$(<"$f")
    verbose "file $f: $(count_lines "$file_content") lines, $(count_chars "$file_content") chars"
    CONTEXT+="<file name=\"$f\">
$file_content
</file>

"
done

if [[ -n "$EXEC_CMD" ]]; then
    verbose "executing: $EXEC_CMD"
    stderr_file=$(mktemp)
    set +e
    exec_stdout=$(timeout 30 bash -c "$EXEC_CMD" 2>"$stderr_file")
    exec_exit=$?
    set -e
    exec_stderr=$(<"$stderr_file")
    rm -f "$stderr_file"

    if [[ "$exec_exit" -eq 124 ]]; then
        echo "error: command timed out after 30s" >&2
        exit 1
    fi

    if [[ -n "$exec_stdout" ]]; then
        CONTEXT+="<stdout>${exec_stdout}</stdout>"$'\n'
    fi
    if [[ -n "$exec_stderr" ]]; then
        CONTEXT+="<stderr>${exec_stderr}</stderr>"$'\n'
    fi
    if [[ "$exec_exit" -ne 0 ]]; then
        CONTEXT+="<exit-code>${exec_exit}</exit-code>"$'\n'
    fi
    CONTEXT+="<source-command>\n${EXEC_CMD}\n</source-command>"$'\n'
fi

if [[ -n "$CONTEXT" ]]; then
    context_lines=$(count_lines "$CONTEXT")
    context_chars=$(count_chars "$CONTEXT")
    verbose "total context before limit: ${context_lines} lines, ${context_chars} chars"

    if $ENFORCE_LIMIT && (( context_lines > MAX_CONTEXT_LINES || context_chars > MAX_CONTEXT_CHARS )); then
        echo "error: context exceeds limit (${context_lines} lines / ${context_chars} chars; max is ${MAX_CONTEXT_LINES} lines / ${MAX_CONTEXT_CHARS} chars)" >&2
        exit 1
    fi
else
    verbose "total context: none"
fi

USER_MESSAGE="${CONTEXT}${QUESTION}"
verbose "sending request to $API_URL (model: $MODEL)..."

# Build JSON payload; extend with thinking fields only when enabled
if $THINKING; then
    PAYLOAD=$(jq -n \
        --arg model "$MODEL" \
        --arg system "$SYSTEM_PROMPT" \
        --arg user "$USER_MESSAGE" \
        '{
            model: $model,
            messages: [
                {role: "system", content: $system},
                {role: "user",   content: $user}
            ],
            thinking: {type: "enabled"},
            stream: true
        }')
else
    PAYLOAD=$(jq -n \
        --arg model "$MODEL" \
        --arg system "$SYSTEM_PROMPT" \
        --arg user "$USER_MESSAGE" \
        '{
            model: $model,
            messages: [
                {role: "system", content: $system},
                {role: "user",   content: $user}
            ],
            stream: true
        }')
fi

# Build auth header array (omitted when no key set)
AUTH_HEADER=()
if [[ -n "$API_KEY" ]]; then
    AUTH_HEADER=(-H "Authorization: Bearer $API_KEY")
fi

curl -sN \
    -H "Content-Type: application/json" \
    "${AUTH_HEADER[@]}" \
    -d "$PAYLOAD" \
    "$API_URL" | stream_response || {
    if [[ ${PIPESTATUS[0]} -ne 0 ]]; then
        echo "error: API request failed — check endpoint and key" >&2
    fi
    exit 1
}

if $VERBOSE; then
    verbose "response complete"
fi
